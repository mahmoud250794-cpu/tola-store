<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tula - دمى محشوة مخصصة | هدايا لا تُنسى</title>
    <meta name="description" content="متجر Tula المتخصص في دمى سلوميشن المخصصة حسب الطلب في فلسطين. صمم دميتك الخاصة الآن.">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts (Cairo) -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Custom Config for Tailwind -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        tula: {
                            pink: '#FFB6C1',
                            darkPink: '#FF69B4',
                            beige: '#F5E6D3',
                            cream: '#FFFEF7',
                            dark: '#333333',
                            gray: '#f3f4f6'
                        }
                    },
                    fontFamily: {
                        sans: ['Cairo', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #FFFEF7;
            color: #333333;
            scroll-behavior: smooth;
        }
        .hero-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffb6c1' fill-opacity='0.2'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        .plushie-preview {
            transition: all 0.3s ease;
        }
        /* Hide scrollbar for clean look */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1; 
        }
        ::-webkit-scrollbar-thumb {
            background: #FFB6C1; 
            border-radius: 4px;
        }
        .section {
            display: none;
            animation: fadeIn 0.5s ease-in-out;
        }
        .section.active {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="flex flex-col min-h-screen">

    <!-- Header -->
    <header class="bg-white shadow-md sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <!-- Logo -->
            <div class="flex items-center gap-2 cursor-pointer" onclick="showSection('home')">
                <i class="fa-solid fa-heart text-tula-darkPink text-3xl"></i>
                <h1 class="text-2xl font-bold text-tula-darkPink tracking-wide">Tula</h1>
            </div>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex gap-6 font-semibold text-gray-700">
                <a href="#" onclick="showSection('home')" class="hover:text-tula-darkPink transition">الرئيسية</a>
                <a href="#" onclick="showSection('products')" class="hover:text-tula-darkPink transition">المنتجات</a>
                <a href="#" onclick="showSection('customize')" class="hover:text-tula-darkPink transition text-tula-darkPink">خصّص دميتك</a>
                <a href="#" onclick="showSection('about')" class="hover:text-tula-darkPink transition">من نحن</a>
                <a href="#" onclick="showSection('contact')" class="hover:text-tula-darkPink transition">اتصل بنا</a>
            </nav>

            <!-- Icons -->
            <div class="flex items-center gap-4">
                <div class="relative cursor-pointer" onclick="toggleCart()">
                    <i class="fa-solid fa-cart-shopping text-xl text-gray-700 hover:text-tula-darkPink transition"></i>
                    <span id="cart-count" class="absolute -top-2 -right-2 bg-tula-darkPink text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">0</span>
                </div>
                <button class="md:hidden text-2xl" onclick="toggleMobileMenu()">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>
        
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t p-4 flex flex-col gap-4 shadow-lg">
            <a href="#" onclick="showSection('home')" class="block text-gray-700">الرئيسية</a>
            <a href="#" onclick="showSection('products')" class="block text-gray-700">المنتجات</a>
            <a href="#" onclick="showSection('customize')" class="block text-tula-darkPink font-bold">خصّص دميتك</a>
            <a href="#" onclick="showSection('about')" class="block text-gray-700">من نحن</a>
            <a href="#" onclick="showSection('contact')" class="block text-gray-700">اتصل بنا</a>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">

        <!-- 1. HOME SECTION -->
        <section id="home" class="section active">
            <!-- Hero -->
            <div class="hero-pattern bg-tula-beige/30 py-16 md:py-24">
                <div class="container mx-auto px-4 flex flex-col md:flex-row items-center gap-8">
                    <div class="md:w-1/2 text-center md:text-right">
                        <h2 class="text-4xl md:text-5xl font-bold mb-4 leading-tight text-gray-800">
                            حول ذكرياتك إلى <span class="text-tula-darkPink">دمى لا تُنسى</span> 🎁
                        </h2>
                        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                            في Tula، نصمم ونطبع دمى سلوميشن مخصصة حسب طلبك. أضف اسمك، رسالتك الخاصة، أو حتى QR Code لجعل هديتك فريدة ومميزة!
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
                            <button onclick="showSection('customize')" class="bg-tula-darkPink text-white px-8 py-3 rounded-full font-bold shadow-lg hover:bg-pink-600 transition transform hover:-translate-y-1">
                                ابدأ التخصيص الآن
                            </button>
                            <button onclick="showSection('products')" class="bg-white text-tula-darkPink border-2 border-tula-darkPink px-8 py-3 rounded-full font-bold hover:bg-tula-pink/20 transition">
                                تصفح المنتجات
                            </button>
                        </div>
                    </div>
                    <div class="md:w-1/2 flex justify-center">
                        <img src="https://images.unsplash.com/photo-1559454403-b8fb87521bc7?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="دمى محشوة" class="rounded-3xl shadow-2xl w-full max-w-md object-cover h-80">
                    </div>
                </div>
            </div>

            <!-- Features -->
            <div class="py-16 bg-white">
                <div class="container mx-auto px-4">
                    <h3 class="text-3xl font-bold text-center mb-12 text-gray-800">كيف تعمل الخدمة؟</h3>
                    <div class="grid md:grid-cols-3 gap-8 text-center">
                        <div class="p-6 bg-tula-cream rounded-xl shadow-sm hover:shadow-md transition">
                            <div class="w-16 h-16 bg-tula-pink/30 rounded-full flex items-center justify-center mx-auto mb-4 text-tula-darkPink text-2xl">
                                <i class="fa-solid fa-pen-nib"></i>
                            </div>
                            <h4 class="font-bold text-xl mb-2">1. صمم</h4>
                            <p class="text-gray-600">اختر نوع الدمية، اللون، وارفع صورتك أو اكتب النص الذي تريده.</p>
                        </div>
                        <div class="p-6 bg-tula-cream rounded-xl shadow-sm hover:shadow-md transition">
                            <div class="w-16 h-16 bg-tula-pink/30 rounded-full flex items-center justify-center mx-auto mb-4 text-tula-darkPink text-2xl">
                                <i class="fa-solid fa-print"></i>
                            </div>
                            <h4 class="font-bold text-xl mb-2">2. نطبع</h4>
                            <p class="text-gray-600">نقوم بطباعة تصميمك بجودة عالية على قماش ناعم وآمن.</p>
                        </div>
                        <div class="p-6 bg-tula-cream rounded-xl shadow-sm hover:shadow-md transition">
                            <div class="w-16 h-16 bg-tula-pink/30 rounded-full flex items-center justify-center mx-auto mb-4 text-tula-darkPink text-2xl">
                                <i class="fa-solid fa-truck-fast"></i>
                            </div>
                            <h4 class="font-bold text-xl mb-2">3. توصيل</h4>
                            <p class="text-gray-600">نرسل لك هديتك المميزة إلى باب منزلك في أي مكان في فلسطين.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Best Sellers Preview -->
            <div class="py-16 bg-tula-gray/30">
                <div class="container mx-auto px-4">
                    <div class="flex justify-between items-center mb-8">
                        <h3 class="text-3xl font-bold text-gray-800">أكثر المنتجات طلباً</h3>
                        <button onclick="showSection('products')" class="text-tula-darkPink font-bold hover:underline">عرض الكل</button>
                    </div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6" id="home-products-grid">
                        <!-- Populated by JS -->
                    </div>
                </div>
            </div>
        </section>

        <!-- 2. PRODUCTS SECTION -->
        <section id="products" class="section">
            <div class="bg-tula-beige py-12 text-center">
                <h2 class="text-4xl font-bold text-gray-800">متجر الدمى</h2>
                <p class="text-gray-600 mt-2">اختر من مجموعتنا الجاهزة أو خصصها بنفسك</p>
            </div>
            <div class="container mx-auto px-4 py-12">
                <!-- Filters -->
                <div class="flex flex-wrap justify-center gap-4 mb-8">
                    <button class="filter-btn active bg-tula-darkPink text-white px-6 py-2 rounded-full" onclick="filterProducts('all')">الكل</button>
                    <button class="filter-btn bg-white border border-gray-300 px-6 py-2 rounded-full hover:bg-tula-pink/20" onclick="filterProducts('animals')">حيوانات</button>
                    <button class="filter-btn bg-white border border-gray-300 px-6 py-2 rounded-full hover:bg-tula-pink/20" onclick="filterProducts('characters')">شخصيات</button>
                    <button class="filter-btn bg-white border border-gray-300 px-6 py-2 rounded-full hover:bg-tula-pink/20" onclick="filterProducts('custom')">جاهزة للتخصيص</button>
                </div>

                <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-8" id="products-grid">
                    <!-- Populated by JS -->
                </div>
            </div>
        </section>

        <!-- 3. CUSTOMIZER SECTION (The Core) -->
        <section id="customize" class="section">
            <div class="container mx-auto px-4 py-8">
                <h2 class="text-3xl font-bold text-center mb-8 text-tula-darkPink">صمم دميتك الخاصة 🎨</h2>
                
                <div class="flex flex-col lg:flex-row gap-8 bg-white p-6 rounded-2xl shadow-xl">
                    
                    <!-- Preview Area -->
                    <div class="lg:w-1/2 bg-tula-gray rounded-xl flex items-center justify-center p-8 relative min-h-[400px]">
                        <!-- Placeholder Image for Plushie -->
                        <img id="preview-image" src="https://cdn-icons-png.flaticon.com/512/2921/2921226.png" alt="Preview" class="h-64 object-contain mix-blend-multiply opacity-80">
                        
                        <!-- Text Overlay Preview -->
                        <div id="preview-text" class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-center font-bold text-gray-800 text-xl pointer-events-none" style="display:none;">
                            <span id="preview-text-content">اسمك هنا</span>
                        </div>
                        
                        <!-- QR Code Overlay Preview -->
                        <div id="preview-qr" class="absolute bottom-4 right-4 w-16 h-16 bg-white p-1 rounded pointer-events-none" style="display:none;">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=TulaStore" class="w-full h-full">
                        </div>
                    </div>

                    <!-- Form Area -->
                    <div class="lg:w-1/2 space-y-6">
                        <!-- Type -->
                        <div>
                            <label class="block font-bold mb-2">نوع الدمية</label>
                            <select id="custom-type" class="w-full border rounded-lg p-3 focus:ring-2 focus:ring-tula-pink outline-none" onchange="updatePreview()">
                                <option value="bear">دب كلاسيكي</option>
                                <option value="rabbit">أرنب</option>
                                <option value="penguin">بطريق</option>
                                <option value="elephant">فيل</option>
                            </select>
                        </div>

                        <!-- Size & Price -->
                        <div class="flex gap-4">
                            <div class="w-1/2">
                                <label class="block font-bold mb-2">الحجم</label>
                                <select id="custom-size" class="w-full border rounded-lg p-3" onchange="calculatePrice()">
                                    <option value="small" data-price="80">صغير (25 سم) - 80₪</option>
                                    <option value="medium" data-price="120">متوسط (40 سم) - 120₪</option>
                                    <option value="large" data-price="180">كبير (60 سم) - 180₪</option>
                                </select>
                            </div>
                            <div class="w-1/2">
                                <label class="block font-bold mb-2">لون القماش</label>
                                <select id="custom-color" class="w-full border rounded-lg p-3">
                                    <option value="#F5E6D3">بيج طبيعي</option>
                                    <option value="#FFB6C1">وردي فاتح</option>
                                    <option value="#E0E0E0">رمادي</option>
                                    <option value="#FFFFFF">أبيض</option>
                                    <option value="#8B4513">بني</option>
                                </select>
                            </div>
                        </div>

                        <!-- Customization Options -->
                        <div class="border-t pt-4">
                            <h4 class="font-bold mb-3 text-tula-darkPink">إضافات خاصة</h4>
                            
                            <div class="mb-4">
                                <label class="block text-sm font-semibold mb-1">النص المطبوع (اسم، رسالة)</label>
                                <input type="text" id="custom-text" placeholder="مثلاً: أحبك يا أمي ❤️" class="w-full border rounded-lg p-2" oninput="updatePreview()">
                            </div>

                            <div class="mb-4 flex items-center gap-2">
                                <input type="checkbox" id="custom-qr" class="w-4 h-4 text-tula-darkPink" onchange="updatePreview()">
                                <label for="custom-qr" class="text-sm">إضافة QR Code (مسح ضوئي)</label>
                            </div>

                            <div class="mb-4">
                                <label class="block text-sm font-semibold mb-1">رفع صورة (اختياري)</label>
                                <input type="file" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-tula-pink/20 file:text-tula-darkPink hover:file:bg-tula-pink/30">
                            </div>
                        </div>

                        <!-- Total & Add to Cart -->
                        <div class="bg-tula-beige/50 p-4 rounded-lg flex justify-between items-center">
                            <div>
                                <span class="block text-sm text-gray-600">السعر الإجمالي</span>
                                <span id="total-price" class="text-2xl font-bold text-tula-darkPink">80₪</span>
                            </div>
                            <button onclick="addToCartFromCustomizer()" class="bg-tula-darkPink text-white px-6 py-3 rounded-lg font-bold hover:bg-pink-600 transition shadow-lg">
                                <i class="fa-solid fa-cart-plus ml-2"></i> إضافة للسلة
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 4. ABOUT US -->
        <section id="about" class="section">
            <div class="container mx-auto px-4 py-16 max-w-4xl">
                <h2 class="text-4xl font-bold text-center mb-8 text-tula-darkPink">قصتنا في Tula</h2>
                <div class="prose prose-lg mx-auto text-gray-700 leading-loose">
                    <p class="mb-4">بدأت حكاية Tula من فكرة بسيطة: أن الهدايا لا يجب أن تكون مجرد أشياء، بل يجب أن تحمل قصصاً وذكريات. نحن متجر فلسطيني متخصص في صناعة الدمى المحشوة (Plushies) المخصصة.</p>
                    <p class="mb-4">نؤمن بأن كل شخص يستحق هدية تحمل اسمه، صورته، أو رسالته الخاصة. لذلك نستخدم أحدث تقنيات الطباعة على الأقمشة لضمان جودة تدوم طويلاً.</p>
                    
                    <div class="grid grid-cols-2 gap-4 my-8 text-center">
                        <div class="bg-white p-4 rounded-lg shadow">
                            <span class="block text-3xl font-bold text-tula-darkPink">+1000</span>
                            <span class="text-sm">عميل سعيد</span>
                        </div>
                        <div class="bg-white p-4 rounded-lg shadow">
                            <span class="block text-3xl font-bold text-tula-darkPink">100%</span>
                            <span class="text-sm">جودة مضمونة</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 5. FAQ -->
        <section id="faq" class="section">
            <div class="container mx-auto px-4 py-16 max-w-3xl">
                <h2 class="text-3xl font-bold text-center mb-8">الأسئلة الشائعة</h2>
                <div class="space-y-4">
                    <details class="bg-white p-4 rounded-lg shadow cursor-pointer">
                        <summary class="font-bold text-lg">كم يستغرق وقت التنفيذ والتوصيل؟</summary>
                        <p class="mt-2 text-gray-600">يستغرق التصنيع من 2 إلى 3 أيام عمل، والتوصيل داخل فلسطين يستغرق من 1 إلى 3 أيام إضافية حسب المدينة.</p>
                    </details>
                    <details class="bg-white p-4 rounded-lg shadow cursor-pointer">
                        <summary class="font-bold text-lg">ما هي طرق الدفع المتاحة؟</summary>
                        <p class="mt-2 text-gray-600">نقبل الدفع عند الاستلام (Cash on Delivery) أو التحويل البنكي المحلي.</p>
                    </details>
                    <details class="bg-white p-4 rounded-lg shadow cursor-pointer">
                        <summary class="font-bold text-lg">هل يمكن إرجاع المنتج المخصص؟</summary>
                        <p class="mt-2 text-gray-600">نظراً لأن المنتجات مصنوعة خصيصاً لك، لا يمكن إرجاعها إلا في حال وجود عيب مصنعي واضح.</p>
                    </details>
                </div>
            </div>
        </section>

        <!-- 6. CONTACT -->
        <section id="contact" class="section">
            <div class="container mx-auto px-4 py-16">
                <div class="grid md:grid-cols-2 gap-12">
                    <div>
                        <h2 class="text-3xl font-bold mb-6">تواصل معنا</h2>
                        <p class="mb-6 text-gray-600">هل لديك استفسار؟ فريقنا جاهز للرد عليك عبر الواتساب أو البريد الإلكتروني.</p>
                        
                        <div class="space-y-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600"><i class="fa-brands fa-whatsapp text-xl"></i></div>
                                <span dir="ltr">+970 59 123 4567</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-pink-100 rounded-full flex items-center justify-center text-pink-600"><i class="fa-brands fa-instagram text-xl"></i></div>
                                <span>@tula.store.ps</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600"><i class="fa-regular fa-envelope text-xl"></i></div>
                                <span>hello@tula.store.ps</span>
                            </div>
                        </div>
                    </div>
                    
                    <form class="bg-white p-6 rounded-xl shadow-lg space-y-4">
                        <input type="text" placeholder="الاسم" class="w-full border p-3 rounded-lg">
                        <input type="email" placeholder="البريد الإلكتروني" class="w-full border p-3 rounded-lg">
                        <textarea rows="4" placeholder="رسالتك" class="w-full border p-3 rounded-lg"></textarea>
                        <button type="button" class="w-full bg-tula-darkPink text-white py-3 rounded-lg font-bold hover:bg-pink-600">إرسال الرسالة</button>
                    </form>
                </div>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white pt-12 pb-6">
        <div class="container mx-auto px-4">
            <div class="grid md:grid-cols-4 gap-8 mb-8">
                <div>
                    <h3 class="text-2xl font-bold text-tula-pink mb-4">Tula</h3>
                    <p class="text-gray-400 text-sm">متجرك الأول للدمى المحشوة المخصصة في فلسطين. نصنع الذكريات.</p>
                </div>
                <div>
                    <h4 class="font-bold mb-4">روابط سريعة</h4>
                    <ul class="space-y-2 text-gray-400 text-sm">
                        <li><a href="#" onclick="showSection('home')" class="hover:text-white">الرئيسية</a></li>
                        <li><a href="#" onclick="showSection('products')" class="hover:text-white">المنتجات</a></li>
                        <li><a href="#" onclick="showSection('customize')" class="hover:text-white">تخصيص دمية</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">سياسات</h4>
                    <ul class="space-y-2 text-gray-400 text-sm">
                        <li><a href="#" class="hover:text-white">سياسة الخصوصية</a></li>
                        <li><a href="#" class="hover:text-white">الشحن والتوصيل</a></li>
                        <li><a href="#" class="hover:text-white">الإرجاع والاستبدال</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">طرق الدفع</h4>
                    <div class="flex gap-2 text-2xl text-gray-400">
                        <i class="fa-regular fa-credit-card"></i>
                        <i class="fa-solid fa-money-bill-wave"></i>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-700 pt-6 text-center text-gray-500 text-sm">
                &copy; 2023 Tula Store. جميع الحقوق محفوظة.
            </div>
        </div>
    </footer>

    <!-- Floating WhatsApp -->
    <a href="https://wa.me/970591234567" target="_blank" class="fixed bottom-6 left-6 bg-green-500 text-white p-4 rounded-full shadow-2xl hover:bg-green-600 transition z-50 animate-bounce">
        <i class="fa-brands fa-whatsapp text-3xl"></i>
    </a>

    <!-- Cart Modal (Hidden by default) -->
    <div id="cart-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex justify-end">
        <div class="bg-white w-full max-w-md h-full p-6 flex flex-col shadow-2xl animate-[slideIn_0.3s_ease-out]">
            <div class="flex justify-between items-center mb-6 border-b pb-4">
                <h3 class="text-2xl font-bold">سلة التسوق</h3>
                <button onclick="toggleCart()" class="text-gray-500 hover:text-red-500"><i class="fa-solid fa-xmark text-2xl"></i></button>
            </div>
            
            <div id="cart-items" class="flex-grow overflow-y-auto space-y-4">
                <!-- Items go here -->
                <p class="text-center text-gray-500 mt-10">السلة فارغة حالياً</p>
            </div>

            <div class="border-t pt-4 mt-4">
                <div class="flex justify-between text-xl font-bold mb-4">
                    <span>المجموع:</span>
                    <span id="cart-total">0₪</span>
                </div>
                <button class="w-full bg-tula-darkPink text-white py-3 rounded-lg font-bold hover:bg-pink-600 transition">إتمام الطلب</button>
            </div>
        </div>
    </div>

    <!-- JavaScript Logic -->
    <script>
        // Data
        const products = [
            { id: 1, name: "دب تيدي كلاسيك", price: 80, category: "animals", image: "https://cdn-icons-png.flaticon.com/512/2921/2921226.png" },
            { id: 2, name: "أرنب ناعم", price: 90, category: "animals", image: "https://cdn-icons-png.flaticon.com/512/2362/2362118.png" },
            { id: 3, name: "دب مخصص", price: 100, category: "custom", image: "https://cdn-icons-png.flaticon.com/512/2921/2921226.png" },
            { id: 4, name: "شخصية كرتونية", price: 120, category: "characters", image: "https://cdn-icons-png.flaticon.com/512/4712/4712035.png" },
            { id: 5, name: "بطريق سعيد", price: 85, category: "animals", image: "https://cdn-icons-png.flaticon.com/512/2362/2362140.png" },
            { id: 6, name: "فيل صغير", price: 95, category: "animals", image: "https://cdn-icons-png.flaticon.com/512/616/616408.png" },
            { id: 7, name: "دب حب", price: 110, category: "custom", image: "https://cdn-icons-png.flaticon.com/512/2921/2921226.png" },
            { id: 8, name: "وحش لطيف", price: 130, category: "characters", image: "https://cdn-icons-png.flaticon.com/512/2362/2362122.png" },
        ];

        let cart = [];

        // Navigation Logic
        function showSection(sectionId) {
            document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            window.scrollTo(0, 0);
            
            // Close mobile menu if open
            document.getElementById('mobile-menu').classList.add('hidden');
        }

        function toggleMobileMenu() {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        }

        // Products Logic
        function renderProducts(filter = 'all') {
            const grid = document.getElementById('products-grid');
            const homeGrid = document.getElementById('home-products-grid');
            grid.innerHTML = '';
            
            // Filter
            const filtered = filter === 'all' ? products : products.filter(p => p.category === filter);

            filtered.forEach(product => {
                const card = `
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition group">
                        <div class="h-48 bg-gray-100 flex items-center justify-center p-4 relative">
                            <img src="${product.image}" alt="${product.name}" class="h-32 object-contain group-hover:scale-110 transition duration-300">
                            ${product.category === 'custom' ? '<span class="absolute top-2 right-2 bg-tula-darkPink text-white text-xs px-2 py-1 rounded">قابل للتخصيص</span>' : ''}
                        </div>
                        <div class="p-4">
                            <h3 class="font-bold text-lg mb-1">${product.name}</h3>
                            <div class="flex justify-between items-center">
                                <span class="text-tula-darkPink font-bold">${product.price}₪</span>
                                <button onclick="addToCart(${product.id})" class="bg-gray-800 text-white w-8 h-8 rounded-full flex items-center justify-center hover:bg-tula-darkPink transition">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                grid.innerHTML += card;
            });

            // Render Home Grid (Top 4)
            if(homeGrid) {
                homeGrid.innerHTML = '';
                products.slice(0, 4).forEach(product => {
                     homeGrid.innerHTML += `
                        <div class="bg-white rounded-xl shadow overflow-hidden text-center p-4">
                             <img src="${product.image}" class="h-24 mx-auto mb-2">
                             <h4 class="font-bold text-sm">${product.name}</h4>
                             <span class="text-tula-darkPink text-xs font-bold">${product.price}₪</span>
                        </div>
                     `;
                });
            }
        }

        function filterProducts(cat) {
            renderProducts(cat);
            // Update buttons style
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-tula-darkPink', 'text-white');
                btn.classList.add('bg-white', 'text-gray-700');
            });
            event.target.classList.remove('bg-white', 'text-gray-700');
            event.target.classList.add('bg-tula-darkPink', 'text-white');
        }

        // Customizer Logic
        function updatePreview() {
            const type = document.getElementById('custom-type').value;
            const text = document.getElementById('custom-text').value;
            const hasQR = document.getElementById('custom-qr').checked;
            
            // Update Image based on type (Using placeholder icons for demo)
            const imgMap = {
                'bear': 'https://cdn-icons-png.flaticon.com/512/2921/2921226.png',
                'rabbit': 'https://cdn-icons-png.flaticon.com/512/2362/2362118.png',
                'penguin': 'https://cdn-icons-png.flaticon.com/512/2362/2362140.png',
                'elephant': 'https://cdn-icons-png.flaticon.com/512/616/616408.png'
            };
            document.getElementById('preview-image').src = imgMap[type];

            // Update Text
            const textEl = document.getElementById('preview-text');
            if(text) {
                textEl.style.display = 'block';
                document.getElementById('preview-text-content').innerText = text;
            } else {
                textEl.style.display = 'none';
            }

            // Update QR
            document.getElementById('preview-qr').style.display = hasQR ? 'block' : 'none';
        }

        function calculatePrice() {
            const sizeSelect = document.getElementById('custom-size');
            const price = sizeSelect.options[sizeSelect.selectedIndex].getAttribute('data-price');
            document.getElementById('total-price').innerText = price + '₪';
            return price;
        }

        function addToCartFromCustomizer() {
            const sizeSelect = document.getElementById('custom-size');
            const price = parseInt(sizeSelect.options[sizeSelect.selectedIndex].getAttribute('data-price'));
            const type = document.getElementById('custom-type').options[document.getElementById('custom-type').selectedIndex].text;
            const text = document.getElementById('custom-text').value;
            
            const item = {
                id: Date.now(), // Unique ID
                name: `دمية مخصصة (${type})`,
                price: price,
                details: text ? `نص: ${text}` : 'بدون نص'
            };
            
            cart.push(item);
            updateCartUI();
            toggleCart(); // Open cart to show user
            alert('تمت الإضافة للسلة بنجاح!');
        }

        // Cart Logic
        function toggleCart() {
            const modal = document.getElementById('cart-modal');
            modal.classList.toggle('hidden');
        }

        function addToCart(id) {
            const product = products.find(p => p.id === id);
            cart.push({ ...product, details: 'منتج جاهز' });
            updateCartUI();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            updateCartUI();
        }

        function updateCartUI() {
            const container = document.getElementById('cart-items');
            const countEl = document.getElementById('cart-count');
            const totalEl = document.getElementById('cart-total');
            
            countEl.innerText = cart.length;
            
            if(cart.length === 0) {
                container.innerHTML = '<p class="text-center text-gray-500 mt-10">السلة فارغة حالياً</p>';
                totalEl.innerText = '0₪';
                return;
            }

            container.innerHTML = '';
            let total = 0;

            cart.forEach((item, index) => {
                total += item.price;
                container.innerHTML += `
                    <div class="flex items-center gap-4 bg-gray-50 p-3 rounded-lg">
                        <div class="w-12 h-12 bg-white rounded flex items-center justify-center">
                            <img src="${item.image || 'https://cdn-icons-png.flaticon.com/512/2921/2921226.png'}" class="w-8 h-8">
                        </div>
                        <div class="flex-grow">
                            <h4 class="font-bold text-sm">${item.name}</h4>
                            <p class="text-xs text-gray-500">${item.details}</p>
                        </div>
                        <div class="text-left">
                            <div class="font-bold text-tula-darkPink">${item.price}₪</div>
                            <button onclick="removeFromCart(${index})" class="text-red-400 text-xs hover:text-red-600">حذف</button>
                        </div>
                    </div>
                `;
            });

            totalEl.innerText = total + '₪';
        }

        // Initialize
        window.onload = function() {
            renderProducts();
            calculatePrice();
        };

    </script>
</body>
</html>